{
  "name": "post-api",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --env-file=.env --watch --experimental-strip-types src/index.ts",
    "start": "NODE_ENV=production node --env-file=.env --experimental-strip-types src/index.ts",
    "outbox:dev": "NODE_ENV=development node --env-file=.env --watch --experimental-strip-types src/workers/outbox.worker.ts",
    "outbox": "NODE_ENV=production node --env-file=.env --experimental-strip-types src/workers/outbox.worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test MONGO_INITDB_DATABASE=tickets_test node --env-file=.env.testing --test --experimental-test-module-mocks --experimental-strip-types",
    "test:watch": "NODE_ENV=test MONGO_INITDB_DATABASE=tickets_test node --env-file=.env.testing --test --watch --experimental-test-module-mocks --experimental-strip-types"
  },
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.9",
    "express": "^5.1",
    "http-status-codes": "^2.3.0",
    "mongodb": "^6.19.0",
    "mongoose": "^8.18.1",
    "supertest": "^7.1.4",
    "uuid": "^13.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/express": "^5.0",
    "@types/node": "^24.3.2",
    "@types/supertest": "^6.0.3",
    "typescript": "^5.9"
  }
}
